PORT=3888
BILI_ROOM_ID=1

# Optional. Fill this with your own Bilibili browser cookie only if danmaku auth requires it.
# Never commit real SESSDATA, bili_jct, DedeUserID, NCM_COOKIE, or any other login credential.
BILI_COOKIE=
BILI_PROTO_VERSION=3

# Danmaku commands. Examples: 点歌 晴天 周杰伦 / 点播: 稻香
REQUEST_COMMANDS=点歌,点播,网易云

MAX_QUEUE_SIZE=30
MAX_SEARCH_RESULTS=8
MIN_REQUEST_INTERVAL_MS=8000
PLAYER_VOLUME=0.75
NCM_QUALITY=standard
NCM_COOKIE=
ALLOW_DUPLICATES=false
AUTOPLAY=true
REQUEST_TIMEOUT_MS=12000
AUDIO_CACHE_MAX_MB=512
AUDIO_CACHE_MAX_FILES=120
